# Modo de streaming
# "direct" = Streaming directo desde YouTube (sin descargar, 0 bytes en disco)
# "download" = Descargar MP3 a carpeta media/ (requiere espacio en disco)
STREAMING_MODE=direct

# YouTube Data API v3 key (obligatoria para obtener la duración real de los videos).
# Obtén una en https://console.cloud.google.com/ y NUNCA la subas al repositorio.
YOUTUBE_API_KEY=

# Orígenes permitidos para CORS: "*" (cualquiera) o lista separada por comas
# Ej: ALLOWED_ORIGINS=https://tuusuario.github.io,https://tudominio.com
ALLOWED_ORIGINS=*

# Cookies de YouTube para que /audio funcione en el servidor (Render bloquea la
# extracción desde IPs de datacenter). Necesario SOLO en producción para tener
# background en móvil; en local no hace falta. Define UNA de las dos:
#   - YTDLP_COOKIES_FILE: ruta a un cookies.txt (en Render, un Secret File: /etc/secrets/cookies.txt)
#   - YTDLP_COOKIES: el contenido del cookies.txt pegado directamente
YTDLP_COOKIES_FILE=
# YTDLP_COOKIES=

# Servidor (usados por `python main.py`)
HOST=0.0.0.0
PORT=8000
RELOAD=false
